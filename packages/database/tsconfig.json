{
  "extends": "@repo/typescript-config/node",
  "compilerOptions": {
    "outDir": "./dist",
    "incremental": true,
    "baseUrl": ".",
    "tsBuildInfoFile": "./dist/tsconfig.tsbuildinfo",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "src",
    "drizzle.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}