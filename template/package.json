{
  "name": "{{PROJECT_NAME}}",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "tooling/*"
    ],
    "catalog": {
      "react": "19.2.0",
      "react-dom": "19.2.0",
      "@types/react": "19.2.7",
      "@types/react-dom": "19.2.3",
      "@types/node": "24.10.1",
      "next": "16.0.5",
      "typescript": "5.9.3",
      "eslint": "9.39.1",
      "prettier": "3.7.2",
      "tailwindcss": "4.1.17",
      "zod": "4.1.13",
      "rimraf": "6.1.2"
    }
  },
  "scripts": {
    "build": "bun run --filter '*' build",
    "dev": "bun run --filter '*' dev",
    "dev:web": "bun run --filter client dev",
    "dev:api": "bun run --filter api dev",
    "dev:mobile": "bun run --filter mobile dev",
    "lint": "bun run --filter '*' lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "bun run --filter '*' check-types"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "typescript": "5.8.3"
  },
  "packageManager": "bun@1.1.38"
}
