{
  "name": "@repo/shared",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc",
    "lint": "eslint . --max-warnings 0 --cache --cache-location .eslintcache",
    "format": "prettier --write .",
